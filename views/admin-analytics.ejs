<!DOCTYPE html>
<html>
<head>

<title>Admin Analytics</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:Arial;
background:#f5f7fb;
padding:30px;
}

h1{
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:30px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

canvas{
max-height:300px;
}

.stats{
display:flex;
gap:20px;
margin-bottom:30px;
}

.stat{
background:white;
padding:20px;
border-radius:10px;
flex:1;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
text-align:center;
}

</style>

</head>

<body>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;">
      <h1>📊 Admin Analytics Dashboard</h1>
      <a href="/admin/dashboard"
         style="text-decoration:none;color:black;font-weight:bold;padding:10px 20px;border-radius:5px;">
        ← Back to Dashboard
      </a>
    </div>

<div class="stats">

<div class="stat">
<h3>Today's Sales</h3>
<h2>₹ <%= todaySales %></h2>
</div>

<div class="stat">
<h3>This Month</h3>
<h2>₹ <%= monthSales %></h2>
</div>

<div class="stat">
<h3>This Year</h3>
<h2>₹ <%= yearSales %></h2>
</div>

</div>

<div class="grid">

<div class="card">
<h3>Most Ordered Fruits</h3>
<canvas id="fruitChart"></canvas>
</div>

<div class="card">
<h3>Daily Revenue</h3>
<canvas id="dailyRevenueChart"></canvas>
</div>

<div class="card">
<h3>Monthly Revenue</h3>
<canvas id="monthlyRevenueChart"></canvas>
</div>

<div class="card">
<h3>Order Status</h3>
<canvas id="statusChart"></canvas>
</div>

<div class="card">
<h3>Sales Distribution</h3>
<canvas id="salesChart"></canvas>
</div>

<div class="card">
<h3>Top Customers</h3>
<canvas id="customerChart"></canvas>
</div>

<div class="card">
<h3>Last 7 Days Sales</h3>
<canvas id="weeklySalesChart"></canvas>
</div>

</div>


<script>

/* DATA FROM SERVER */

const fruitData = <%- JSON.stringify(fruitMap) %>;
const dailyRevenue = <%- JSON.stringify(dailyRevenue) %>;
const monthlyRevenue = <%- JSON.stringify(monthlyRevenue) %>;
const statusData = <%- JSON.stringify(statusMap) %>;
const customerData = <%- JSON.stringify(customerMap) %>;
const weeklySales = <%- JSON.stringify(weeklySales) %>;


/* FRUIT CHART */

new Chart(document.getElementById("fruitChart"),{
type:"bar",
data:{
labels:Object.keys(fruitData),
datasets:[{
label:"Orders",
data:Object.values(fruitData)
}]
}
});


/* DAILY REVENUE */

new Chart(document.getElementById("dailyRevenueChart"),{
type:"line",
data:{
labels:Object.keys(dailyRevenue),
datasets:[{
label:"Revenue",
data:Object.values(dailyRevenue)
}]
}
});


/* MONTHLY REVENUE */

new Chart(document.getElementById("monthlyRevenueChart"),{
type:"line",
data:{
labels:Object.keys(monthlyRevenue),
datasets:[{
label:"Monthly Revenue",
data:Object.values(monthlyRevenue)
}]
}
});


/* ORDER STATUS */

new Chart(document.getElementById("statusChart"),{
type:"pie",
data:{
labels:Object.keys(statusData),
datasets:[{
data:Object.values(statusData)
}]
}
});


/* SALES DISTRIBUTION */

new Chart(document.getElementById("salesChart"),{
type:"doughnut",
data:{
labels:["Today","Month","Year"],
datasets:[{
data:[
<%= todaySales %>,
<%= monthSales %>,
<%= yearSales %>
]
}]
}
});


/* TOP CUSTOMERS */

new Chart(document.getElementById("customerChart"),{
type:"bar",
data:{
labels:Object.keys(customerData),
datasets:[{
label:"Spent",
data:Object.values(customerData)
}]
}
});

/* WEEKLY SALES */

new Chart(document.getElementById("weeklySalesChart"),{
type:"bar",
data:{
labels:Object.keys(weeklySales),
datasets:[{
label:"Sales",
data:Object.values(weeklySales)
}]
}
});

</script>

</body>
</html>