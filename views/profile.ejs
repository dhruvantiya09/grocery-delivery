<!DOCTYPE html>
<html>
<head>
  <title>My Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-br from-gray-100 to-gray-200 min-h-screen py-10">

<div class="max-w-5xl mx-auto px-6">

  <!-- PROFILE HEADER CARD -->
  <div class="bg-white rounded-3xl shadow-xl p-8 mb-8 flex justify-between items-center">

    <div class="flex items-center gap-6">

      <!-- Avatar -->
      <div class="w-20 h-20 rounded-full bg-gradient-to-r from-blue-500 to-indigo-600 
      flex items-center justify-center text-white text-3xl font-bold shadow-lg">

        <%= user.name.charAt(0).toUpperCase() %>

      </div>

      <div>
        <h1 class="text-2xl font-bold text-gray-800">
          <%= user.name %>
        </h1>

        <p class="text-gray-500">
          <%= user.email %>
        </p>

        <p class="text-sm text-gray-400">
          Customer Account
        </p>
      </div>

    </div>

    <!-- Logout Button -->
    <form action="/logout" method="POST">

      <button
        class="bg-red-500 hover:bg-red-600 text-white px-6 py-2 rounded-xl shadow font-semibold transition">
        Logout
      </button>

    </form>

  </div>


  <!-- PROFILE FORM CARD -->
  <div class="bg-white rounded-3xl shadow-xl p-10">

    <h2 class="text-xl font-semibold mb-8 text-gray-800">
      Personal Information
    </h2>

    <form action="/profile/update" method="POST">

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Name -->
        <div>
          <label class="text-sm text-gray-500">Full Name</label>

          <input
            type="text"
            name="name"
            value="<%= user.name %>"
            class="mt-1 w-full border border-gray-300 px-4 py-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"
            required>
        </div>


        <!-- Email -->
        <div>
          <label class="text-sm text-gray-500">Email</label>

          <input
            type="email"
            name="email"
            value="<%= user.email %>"
            class="mt-1 w-full border border-gray-300 px-4 py-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"
            required>
        </div>


        <!-- Phone -->
        <div>
          <label class="text-sm text-gray-500">Phone</label>

          <input
            type="tel"
            name="phone"
            value="<%= user.phone || '' %>"
            placeholder="Enter 10 digit phone number"
            pattern="[0-9]{10}"
            class="mt-1 w-full border border-gray-300 px-4 py-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"
            required>
        </div>


        <!-- Address -->
        <div class="md:col-span-2">

          <label class="text-sm text-gray-500">Delivery Address</label>

          <textarea
            name="address"
            rows="3"
            class="mt-1 w-full border border-gray-300 px-4 py-3 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none"
            placeholder="Enter your full delivery address"
            required><%= user.address || '' %></textarea>

        </div>

      </div>


      <!-- BUTTONS -->
      <div class="mt-10 flex justify-between items-center">

        <a href="/shop"
           class="text-blue-600 hover:underline font-medium">
           ← Back to Shop
        </a>


        <div class="flex gap-4">

          <button
            type="button"
            onclick="window.location.href='/confirm-address'"
            class="bg-gray-800 hover:bg-gray-900 text-white px-6 py-3 rounded-xl shadow font-semibold transition">
            Back to Payment
          </button>

          <button
            type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl shadow font-semibold transition">
            Update Profile
          </button>

        </div>

      </div>

    </form>

  </div>

</div>

</body>
</html>