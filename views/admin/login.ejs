<!DOCTYPE html>
<html>
<head>
  <title>Admin Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/tsparticles@2/tsparticles.bundle.min.js"></script>

</head>

<body class="bg-gradient-to-br from-gray-900 via-gray-800 to-black flex items-center justify-center min-h-screen">

  <div id="tsparticles" class="fixed inset-0 -z-10"></div>


  <form method="POST" action="/admin/login"
        onsubmit="showLoading()"
        class="bg-gray-800/90 backdrop-blur-md p-10 rounded-2xl shadow-2xl w-96 border border-gray-700 transition duration-300">

    <!-- Heading -->
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-white tracking-wide">
        Admin Access
      </h2>
      <div class="flex justify-center mt-3">
  <span class="bg-blue-600/20 text-blue-400 text-xs px-3 py-1 rounded-full border border-blue-500">
    ADMIN ROLE
  </span>
</div>

      <p class="text-gray-400 text-sm mt-1">
        Restricted Control Panel
      </p>
    </div>

    <!-- Error Message -->
    <% if (typeof error !== "undefined") { %>
      <div class="bg-red-500/10 border border-red-500 text-red-400 text-sm p-3 rounded-lg mb-4 text-center animate-pulse">
        <%= error %>
      </div>
    <% } %>

    <!-- Email -->
    <div class="mb-5">
      <label class="block text-gray-300 text-sm mb-1">Email</label>
      <input type="email" name="email" required
             class="w-full px-4 py-2 rounded-lg bg-gray-700 text-white border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200"
             placeholder="admin@email.com">
    </div>

    <!-- Password -->
    <div class="mb-6">
      <label class="block text-gray-300 text-sm mb-1">Password</label>

      <div class="relative">
        <input 
  type="password"
  name="password"
  id="password"
  maxlength="8"
  class="w-full px-3 py-2 tracking-[8px] text-center text-xl font-bold rounded-lg bg-gray-700 text-white border border-gray-600 focus:outline-none focus:ring-2 focus:ring-blue-500 transition"
  placeholder="********"
  required
>


        <div class="flex items-center mb-4">
  <input type="checkbox" name="remember" class="mr-2 mt-3">
  <label class="text-gray-400 text-sm mt-3">Remember Me</label>
</div>


        <button 
          type="button"
          onclick="togglePassword()"
          class="absolute pb-8 right-4 top-1/2 -translate-y-1/2 text-gray-400 hover:text-blue-400 transition"
        >
          <span id="eyeIcon">👁️</span>
        </button>
      </div>
    </div>

    <!-- Button -->
    <button 
      id="loginBtn"
      class="w-full bg-blue-600 hover:bg-blue-700 active:scale-95 transition duration-200 text-white py-2 rounded-lg font-semibold tracking-wide shadow-md">
      Sign In
    </button>

    <!-- Footer -->
    <p class="text-center text-xs text-gray-500 mt-6">
      Secure Admin Environment
    </p>

  </form>
  
  <script>
  
  window.addEventListener("load", () => {
    tsParticles.load("tsparticles", {
      fullScreen: { enable: false },
      background: { color: "transparent" },
      particles: {
        number: { value: 80 },
        size: { value: 2 },
        move: { enable: true, speed: 1 },
        links: {
          enable: true,
          distance: 120,
          color: "#3b82f6",
          opacity: 0.4
        },
        color: { value: "#3b82f6" }
      }
    });
  });


    function togglePassword() {
      const password = document.getElementById("password");
      const eyeIcon = document.getElementById("eyeIcon");

      if (password.type === "password") {
        password.type = "text";
        eyeIcon.innerText = "🙈";
      } else {
        password.type = "password";
        eyeIcon.innerText = "👁️";
      }
    }

    function showLoading() {
      const btn = document.getElementById("loginBtn");
      btn.innerText = "Signing In...";
      btn.disabled = true;
      btn.classList.add("opacity-70");
    }

  </script>

</body>

</html>
