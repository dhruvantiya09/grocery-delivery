<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
font-family:'Inter',sans-serif;
}
</style>

</head>

<body class="bg-gray-50">

<!-- NAVBAR -->
<header class="bg-white shadow-sm border-b">
<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

<div>
<h1 class="text-2xl font-bold text-gray-800">Admin Dashboard</h1>
<p class="text-sm text-gray-500">Grocery Management System</p>
</div>

<div class="flex gap-3">

<a href="/admin/analytics"
class="bg-green-700 hover:bg-gray-800 text-white px-4 py-2 rounded-lg shadow">
  Analytics
</a>

<a href="/admin/staff"
class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg shadow">
Manage Staff
</a>

<a href="/admin/expenses"
class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg shadow">
Add Expenses
</a>

<a href="/admin/complaints"
class="bg-yellow-500 hover:bg-yellow-600 text-white px-5 py-2 rounded-lg transition">
Customer Complaints
</a>

<form action="/admin/logout" method="POST">
<button
class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg shadow">
Logout
</button>
</form>

</div>

</div>
</header>

<div class="max-w-7xl mx-auto px-6 py-8">

<!-- STATS -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

<div class="bg-white rounded-2xl shadow p-6 border hover:shadow-lg transition">
<p class="text-gray-500">Total Orders</p>
<h2 class="text-3xl font-bold mt-2">
<%= orders ? orders.length : 0 %>
</h2>
</div>

<div class="bg-white rounded-2xl shadow p-6 border hover:shadow-lg transition">
<p class="text-gray-500">Revenue</p>
<h2 class="text-3xl font-bold text-green-600 mt-2">
₹ <%= revenue %>
</h2>
</div>

<div class="bg-white rounded-2xl shadow p-6 border hover:shadow-lg transition">
<p class="text-gray-500">Profit</p>
<h2 class="text-3xl font-bold text-indigo-600 mt-2">
₹ <%= profit %>
</h2>
</div>

</div>

<!-- ORDERS -->
<div class="bg-white rounded-2xl shadow border overflow-hidden">

<div class="p-6 border-b">
<h2 class="text-xl font-semibold text-gray-800">Orders</h2>
</div>

<div class="overflow-x-auto">

<table class="min-w-full text-sm">

<thead class="bg-gray-100 text-gray-600 uppercase text-xs">

<tr>
<th class="p-3">Order ID</th>
<th class="p-3">Customer</th>
<th class="p-3">Product</th>
<th class="p-3">Price</th>
<th class="p-3">Qty</th>
<th class="p-3">Total</th>
<th class="p-3">Status</th>
<th class="p-3">Action</th>
</tr>

</thead>

<tbody>

<% if (orders && orders.length > 0) { %>

<% orders.forEach(order => { %>

<% order.items.forEach((item, index) => { %>

<tr class="border-t hover:bg-gray-50 transition">

<% if(index===0){ %>

<td class="p-3 font-medium" rowspan="<%= order.items.length %>">
#<%= order._id.toString().slice(-6) %>
</td>

<td class="p-3" rowspan="<%= order.items.length %>">
<%= order.user ? order.user.name : "Unknown" %>
</td>

<% } %>

<td class="p-3"><%= item.name %></td>

<td class="p-3">₹ <%= item.price %></td>

<td class="p-3"><%= item.qty %></td>

<% if(index===0){ %>

<td class="p-3 font-semibold" rowspan="<%= order.items.length %>">
₹ <%= order.totalAmount %>
</td>

<td class="p-3" rowspan="<%= order.items.length %>">

<span class="px-3 py-1 rounded-full text-xs font-medium
<%= order.status==='Pending'?'bg-yellow-100 text-yellow-700':'' %>
<%= order.status==='Delivered'?'bg-green-100 text-green-700':'' %>
<%= order.status==='Cancelled'?'bg-red-100 text-red-700':'' %>">

<%= order.status %>

</span>

</td>

<td class="p-3" rowspan="<%= order.items.length %>">

<form action="/admin/update-status/<%= order._id %>" method="POST" class="flex gap-2">

<select name="status"
class="border rounded px-2 py-1 text-sm">

<option value="Pending">Pending</option>
<option value="Delivered">Delivered</option>
<option value="Cancelled">Cancelled</option>

</select>

<button
class="bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1 rounded">

Update

</button>

</form>

</td>

<% } %>

</tr>

<% }) %>

<% }) %>

<% } else { %>

<tr>
<td colspan="8" class="p-8 text-center text-gray-500">
No orders yet
</td>
</tr>

<% } %>

</tbody>

</table>

</div>

</div>

</div>

</body>
</html>