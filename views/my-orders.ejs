<!DOCTYPE html>
<html>

<head>
  <title>My Orders</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50 min-h-screen p-8">

  <div class="max-w-5xl mx-auto">

    <!-- Back Button -->
    <div>
      <button onclick="history.back()"
        class="flex items-center gap-2 text-gray-600 hover:text-emerald-600 transition font-medium">
        ← Back
      </button>
    </div>

    <!-- Header -->
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold">My Orders</h1>

      <% if (orders && orders.length> 0) { %>
        <a href="/shop" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg shadow transition">
          Shop More
        </a>
        <% } %>
    </div>

    <!-- Error -->
    <% if (error) { %>
      <div class="bg-red-100 text-red-700 p-4 rounded-lg mb-6">
        <%= error %>
      </div>
      <% } %>

        <!-- Orders -->
        <% if (orders && orders.length> 0) { %>

          <div class="space-y-8">

            <% orders.forEach(order=> { %>

              <div class="bg-white rounded-2xl shadow-md p-6 hover:shadow-lg transition">

                <!-- Top Info -->
                <div class="flex flex-wrap justify-between items-center gap-4">

                  <div>
                    <p class="text-sm text-gray-500">Order ID</p>
                    <p class="font-semibold text-lg">
                      <%= order._id.toString().slice(-6) %>
                    </p>

                    <p class="text-sm text-gray-400 mt-1">
                      <%= order.createdAt.toDateString() %>
                    </p>
                  </div>

                  <div class="text-right">
                    <p class="text-sm text-gray-500">Total Amount</p>
                    <p class="text-xl font-bold text-green-600">
                      ₹ <%= order.totalAmount %>
                    </p>
                  </div>

                  <div>
                    <span class="px-4 py-1 rounded-full text-sm font-semibold
<%= order.status === 'Cancelled' ? 'bg-red-100 text-red-600' :
order.status === 'Delivered' ? 'bg-green-100 text-green-600' :
order.status === 'Shipped' ? 'bg-blue-100 text-blue-600' :
'bg-yellow-100 text-yellow-600' %>">
                      <%= order.status %>
                    </span>
                  </div>

                </div>

                <!-- Order Timeline -->
                <div class="mt-6 border-l-4 border-green-500 pl-4">

                  <p class="text-sm font-semibold text-green-600">
                    ✔ Order Placed
                  </p>

                  <% if(order.status==="Pending" ){ %>
                    <p class="text-sm text-yellow-600">
                      ⏳ Processing
                    </p>
                    <% } %>

                      <% if(order.status==="Shipped" ){ %>
                        <p class="text-sm text-blue-600">
                          🚚 Out for Delivery
                        </p>
                        <% } %>

                          <% if(order.status==="Delivered" ){ %>
                            <p class="text-sm text-green-600">
                              📦 Delivered
                            </p>
                            <% } %>

                              <% if(order.status==="Cancelled" ){ %>
                                <p class="text-sm text-red-600">
                                  ❌ Order Cancelled
                                </p>
                                <% } %>

                </div>

                <!-- Items -->
                <div class="mt-6 border-t pt-6 space-y-4">

                  <% order.items.forEach(item=> { %>

                    <div class="flex gap-4 items-center">

                      <img src="<%= item.image %>" alt="<%= item.name %>" class="w-16 h-16 object-cover rounded-md">

                      <div>
                        <p class="font-semibold">
                          <%= item.name %>
                        </p>
                        <p>₹ <%= item.price %> × <%= item.qty %>
                        </p>
                      </div>

                    </div>

                    <% }) %>
                </div>

                    <!-- Buttons -->
                    <div class="flex justify-end mt-6 gap-3">

                      <% if (order.status !=="Cancelled" && order.status !=="Delivered" ) { %>
                        <form action="/order/cancel/<%= order._id %>" method="POST"
                          onsubmit="return confirm('Cancel this order?')">

                          <button class="bg-red-500 hover:bg-red-600 text-white px-5 py-2 rounded-lg transition">
                            Cancel Order
                          </button>

                        </form>
                        <% } %>

                          <% if (order.status==="Cancelled" ) { %>
                            <form action="/order/delete/<%= order._id %>" method="POST"
                              onsubmit="return confirm('Delete this order?')">

                              <button class="bg-gray-700 hover:bg-black text-white px-5 py-2 rounded-lg transition">
                                Delete
                              </button>

                            </form>
                            <% } %>

                              <a href="/order/<%= order._id %>"
                                class="bg-gray-800 hover:bg-black text-white px-5 py-2 rounded-lg transition">
                                View Details
                              </a>

                    </div>

              </div>

              <% }) %>

          </div>

          <% } else { %>

            <!-- No Orders -->

            <div class="bg-white rounded-xl shadow p-10 text-center space-y-4">

              <p class="text-gray-500 text-lg">
                You have no orders yet.
              </p>

              <a href="/shop"
                class="inline-block bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-lg shadow transition">
                Shop More
              </a>

            </div>

            <% } %>

  </div>

</body>

</html>