<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shop</title>

  <link rel="stylesheet" href="/main.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

  <!-- ================= HEADER ================= -->
  <section class="max-w-7xl mx-auto px-6 py-10">
    <h1 class="text-4xl font-bold text-center mb-4">
      Our <span class="text-emerald-600">Products</span>
    </h1>

    <div class="mb-6 flex justify-between items-center">

      <!-- Back Button -->
      <button onclick="window.location.href='/'"
        class="flex items-center gap-2 text-gray-600 hover:text-emerald-600 transition font-medium">
        ← Back
      </button>

      <!-- Next Button -->
      <button onclick="goNext()"
        class="flex items-center gap-2 text-gray-600 hover:text-emerald-600 transition font-medium">
        Next →
      </button>

    </div>


    <p class="text-center text-gray-600">
      Explore our wide range of fresh and quality products!

  </section>

  <!-- ================= CATEGORY FILTER ================= -->
  <section class="max-w-7xl mx-auto px-6 mb-10">

    <div class="flex flex-wrap justify-center gap-4">

      <!-- ALL Button -->
      <button onclick="filterCategory('all', this)"
        class="category-btn bg-emerald-600 text-white px-5 py-2 rounded-full transition">
        All
      </button>

      <% if (categories && categories.length> 0) { %>
        <% categories.forEach(category=> { %>

          <button onclick="filterCategory('<%= category.name %>', this)"
            class="category-btn bg-white border border-gray-300 px-5 py-2 rounded-full hover:bg-green-600 transition">
            <%= category.name %>
          </button>

          <% }) %>
            <% } %>

    </div>

  </section>

  <!-- ================= PRODUCT GRID ================= -->
  <section class="max-w-7xl mx-auto px-6 pb-16">

    <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

      <% if (products && products.length> 0) { %>
        <% products.forEach(product=> { %>

          <div
            class="product-card bg-white rounded-2xl shadow-md hover:shadow-2xl hover:-translate-y-1 transition duration-300 flex flex-col overflow-hidden"
            data-category="<%= product.category %>">

            <!-- Image -->
            <div class="h-52 overflow-hidden">
              <img src="<%= product.image || '/images/default.png' %>" alt="<%= product.name %>"
                class="w-full h-full object-cover hover:scale-105 transition duration-300"
                onerror="this.src='/images/default.png'">
            </div>

            <!-- Info -->
            <div class="p-5 flex flex-col flex-grow">

              <h2 class="text-lg font-semibold mb-1">
                <%= product.name %>
              </h2>

              <p class="text-gray-400 text-sm mb-2">
                Fresh grocery item
              </p>

              <p class="text-emerald-600 font-bold text-xl mb-4">
                ₹ <%= product.price %>
              </p>

              <form action="/add/<%= product._id %>" method="POST" class="mt-auto">

                <!-- Quantity -->
                <div class="flex items-center justify-center gap-4 mb-4">

                  <button type="button" onclick="changeQty('<%= product._id %>', -1)"
                    class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-300 hover:bg-gray-100 transition">
                    −
                  </button>

                  <input type="number" name="quantity" id="qty-<%= product._id %>" value="1" min="1" readonly
                    class="w-12 text-center border rounded-lg py-1">

                  <button type="button" onclick="changeQty('<%= product._id %>', 1)"
                    class="w-9 h-9 flex items-center justify-center rounded-full border border-gray-300 hover:bg-gray-100 transition">
                    +
                  </button>

                </div>

                <button type="button" onclick="addToCart('<%= product._id %>')"
                  class="w-full bg-emerald-600 text-white py-2 rounded-xl font-semibold hover:bg-emerald-700 transition">
                  Add to Cart
                </button>

                <button class="text-red-500">
                  ❤️ Add to Wishlist
                </button>

              </form>

            </div>

          </div>

          <% }) %>
            <% } %>

    </div>

  </section>

  <div id="toast" class="fixed bottom-6 right-6 bg-green-600 text-white px-5 py-3 rounded-lg shadow-lg hidden z-50">
  </div>

  <!-- ================= JAVASCRIPT ================= -->
  <script>

    // Quantity Function
   function changeQty(id, change) {
  const input = document.getElementById("qty-" + id);
  if (!input) return;

  let value = parseInt(input.value) || 1;
  value += change;

  if (value < 1) value = 1;

  input.value = value;

  // Save quantity in localStorage
  localStorage.setItem("qty-" + id, value);
}

    // Category Filter
    function filterCategory(category, btn) {

      const cards = document.querySelectorAll(".product-card");

      cards.forEach(card => {
        const productCategory = card.getAttribute("data-category");

        if (category === "all" || productCategory === category) {
          card.style.display = "flex";
        } else {
          card.style.display = "none";
        }
      });

      // Active Button Style
      document.querySelectorAll(".category-btn").forEach(button => {
        button.classList.remove("bg-green-600", "text-white");
        button.classList.add("bg-white", "border", "border-gray-300");
      });

      btn.classList.remove("bg-white", "border", "border-gray-300");
      btn.classList.add("bg-green-600", "text-white");
    }

    // Next Button Function
    function goNext() {
      window.location.href = "/confirm-address"; // change this to wherever you want
    }

    function showToast(message) {

      const toast = document.getElementById("toast");

      toast.innerText = message;
      toast.classList.remove("hidden");

      setTimeout(() => {
        toast.classList.add("hidden");
      }, 2000);
    }

    async function addToCart(id) {

      const qtyInput = document.getElementById("qty-" + id);
      const quantity = qtyInput ? qtyInput.value : 1;

      const res = await fetch(`/cart/add/${id}`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ quantity })
      });

      if (res.ok) {
        showToast("✅ Product added to cart");
      } else {
        showToast("❌ Failed to add");
      }

    }

    // Restore saved quantities
window.addEventListener("load", () => {

  const inputs = document.querySelectorAll("input[id^='qty-']");

  inputs.forEach(input => {

    const savedQty = localStorage.getItem(input.id);

    if (savedQty) {
      input.value = savedQty;
    }

  });

});

  </script>

</body>

</html>